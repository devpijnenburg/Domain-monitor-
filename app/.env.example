# Database password (used by PostgreSQL and Django)
DB_PASSWORD=changeme_db_password

# Django secret key — must be at least 50 random characters
SECRET_KEY=changeme_secret_key_min_50_chars_long_replace_this

# SMTP alerting (leave blank to disable email alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Telegram alerting (leave blank to disable Telegram alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# internet.nl Dashboard API base URL (default: local service)
DASHBOARD_API_URL=http://localhost:8000
DASHBOARD_API_TOKEN=
